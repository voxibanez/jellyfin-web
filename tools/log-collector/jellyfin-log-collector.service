[Unit]
Description=Jellyfin playback diagnostics upload collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jellyfin-log
Group=jellyfin-log
ExecStart=/usr/bin/jellyfin-log-collector -config /etc/jellyfin-log-collector/config.toml
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/jellyfin-log-collector

[Install]
WantedBy=multi-user.target
